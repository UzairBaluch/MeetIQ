# Server
NODE_ENV=development
PORT=6000
LOG_LEVEL=debug

# CORS (comma-separated origins; omit in development to allow all)
# CORS_ORIGIN=http://localhost:3000

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meetiq?schema=public
REDIS_URL=redis://localhost:6379

# Auth (required before Phase 1 auth routes)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=30d
